{
  "name": "template-hub",
  "version": "1.0.0",
  "description": "Azure DevOps extension for Template Hub",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf ./dist && rimraf *.vsix",
    "compile": "npm run clean && webpack --mode production",
    "compile:dev": "npm run clean && webpack --mode development",
    "build": "npm run compile",
    "build:dev": "npm run compile:dev",
    "serve": "webpack-dev-server --config webpack.config.js --host localhost --port 8080 --open",
    "package": "npm run build && tfx extension create --manifest-globs vss-extension.json --rev-version",
    "package-extension": "tfx extension create --manifest-globs vss-extension.json --rev-version",
    "publish-extension": "tfx extension publish --manifest-globs vss-extension.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moimhossain/template-hub.git"
  },
  "keywords": [
    "azure-devops",
    "extensions",
    "template-hub"
  ],
  "author": "Moim Hossain",
  "license": "MIT",
  "dependencies": {
    "azure-devops-extension-api": "^4.234.0",
    "azure-devops-extension-sdk": "^3.1.2",
    "azure-devops-ui": "2.245.0",
    "react": "~16.13.1",
    "react-dom": "~16.13.1"
  },
  "devDependencies": {
    "@types/react": "~16.8.2",
    "@types/react-dom": "~16.8.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.7.1",
    "rimraf": "~2.6.2",
    "sass": "^1.62.1",
    "sass-loader": "^13.0.0",
    "style-loader": "^3.3.4",
    "tfx-cli": "^0.11.0",
    "ts-loader": "~5.2.2",
    "typescript": "^4.4.4",
    "webpack": "^5.23.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
