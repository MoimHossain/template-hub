{
    "manifestVersion": 1,
    "id": "template-hub",
    "publisher": "MoimHossain",
    "version": "0.0.22",
    "name": "Template Hub",
    "description": "Azure DevOps extension for managing and governing templates across your organization.",
    "public": false,
    "categories": [
        "Azure Repos"
    ],
    "icons": {
        "default": "assets/images/ext-logo.png"
    },
    "targets": [
        {
            "id": "Microsoft.VisualStudio.Services"
        }
    ],
    "scopes": [
        "vso.project",
        "vso.code",
        "vso.graph",
        "vso.extension.data_write"
    ],
    "contributions": [
        {
            "id": "organization-settings-hub",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-web.collection-admin-hub-group"
            ],
            "properties": {
                "order": 1,
                "icon": {
                    "light": "assets/images/settings.png",
                    "dark": "assets/images/settings.png"
                },
                "name": "Template Hub",
                "uri": "dist/organizationSettings/index.html"
            }
        },
        {
            "id": "governed-templates",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-web.project-admin-hub-group"
            ],
            "properties": {
                "order": 100,
                "icon": {
                    "light": "assets/images/governance.png",
                    "dark": "assets/images/governance.png"
                },
                "name": "One Template (ING)",
                "uri": "dist/governedTemplates/index.html"
            }
        },
        {
            "id": "template-marketplace",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-build-web.build-release-hub-group"
            ],
            "properties": {
                "order": 100,
                "icon": {
                    "light": "assets/images/hub.png",
                    "dark": "assets/images/hub.png"
                },
                "name": "Template Marketplace (ING)",
                "uri": "dist/templateMarketplace/index.html"
            }
        },
        {
            "id": "template-usage-tracker-decorator",
            "type": "ms.azure-pipelines.pipeline-decorator",
            "targets": [
                "ms.azure-pipelines-agent-job.pre-job-tasks"
            ],
            "properties": {
                "template": "decorators/template-usage-tracker/template-usage-tracker.yml"
            }
        }
    ],
    "content": {
        "details": {
            "path": "overview.md"
        }
    },
    "files": [
        {
            "path": "assets",
            "addressable": true
        },
        {
            "path": "dist",
            "addressable": true
        },
        {
            "path": "decorators",
            "addressable": true,
            "contentType": "text/plain"
        }
    ]
}
